{
  "hooks": {
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "python .claude/hooks/log-subagent-start.py" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "python .claude/hooks/log-subagent-stop.py" }
        ]
      },
      {
        "matcher": "linkedin-reader-techie|linkedin-reader-beamter|linkedin-reader-bedenkentraeger",
        "hooks": [
          { "type": "command", "command": "python .claude/hooks/validate-reader-json.py" }
        ]
      }
    ]
  }
}